generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  PURCHASE_MANAGER
  PURCHASE_AGENT
  REQUESTER
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum QuotationRequestStatus {
  DRAFT
  SENT
  RECEIVED
  COMPARING
  APPROVED
  REJECTED
  CANCELLED
}

enum QuotationStatus {
  PENDING
  RECEIVED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  IN_PROGRESS
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PurchaseOrderItemStatus {
  PENDING
  PARTIALLY_RECEIVED
  RECEIVED
}

enum MaterialCategory {
  CONSTRUCTION_MATERIALS
  ELECTRICAL
  PLUMBING
  HARDWARE
  PAINT
  SAFETY_EQUIPMENT
  TOOLS
  MACHINERY
  TECHNOLOGY
  OTHER
}

enum UnitOfMeasure {
  UNITS
  KG
  TON
  METER
  LITER
  BOX
  BAG
  PALLET
}

// ============================================
// USUARIOS Y AUTENTICACIÓN
// ============================================

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  email     String?
  role      UserRole @default(REQUESTER)
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotationRequestsCreated   QuotationRequest[] @relation("UserQuotationRequests")
  quotationsReceived        Quotation[]
  purchaseOrdersCreated     PurchaseOrder[]
  purchaseOrdersApproved     PurchaseOrder[]    @relation("ApprovedBy")
}

// ============================================
// PROVEEDORES
// ============================================

model Supplier {
  id          String         @id @default(uuid())
  code        String         @unique
  name        String
  rut         String?        // NIT de la empresa (RUT)
  nit         String?        // NIT - número de identificación tributaria
  rutFile     String?        // Ruta al archivo PDF del RUT
  address     String?
  city        String?
  country     String         @default("Chile")
  phone       String?
  email       String?
  contactName String?        // Persona de contacto
  contactPhone String?
  contactEmail String?
  bankAccount String?        // Cuenta bancaria
  bankName    String?
  paymentTerms String?       // Términos de pago (ej: "30 días")
  notes       String?
  categories  String[]       // Categorías de materiales que provee
  status      SupplierStatus @default(ACTIVE)
  rating      Float?         // Calificación (1-5)
  
  quotationsReceived Quotation[]
  purchaseOrders     PurchaseOrder[]
  workOrders        WorkOrder[]
  contracts         Contract[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// CATÁLOGO DE MATERIALES
// ============================================

model Material {
  id            String          @id @default(uuid())
  code          String          @unique
  name          String
  description   String?
  category      MaterialCategory
  unitOfMeasure UnitOfMeasure
  defaultUnitPrice Float?
  minStock      Float?
  isActive      Boolean         @default(true)
  
  // Relación con items
  quotationRequestItems QuotationRequestItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// SOLICITUDES DE COTIZACIÓN (RFQ)
// ============================================

model QuotationRequest {
  id              String                @id @default(uuid())
  code            String                @unique
  title           String
  description     String?
  projectName     String?               // Nombre de la obra/proyecto
  priority        String?               // URGENT, HIGH, NORMAL, LOW
  requiredDate    DateTime?             // Fecha requerida
  deliveryAddress String?               // Dirección de entrega
  status          QuotationRequestStatus @default(DRAFT)
  
  // Usuario que creó la solicitud
  createdById     String
  createdBy       User                  @relation("UserQuotationRequests", fields: [createdById], references: [id])
  
  // Proveedores a los que se envió
  quotations      Quotation[]
  
  // Items solicitados
  items           QuotationRequestItem[]
  
  // Cotización seleccionada
  selectedQuotationId String?
  
  // Contratos asociados
  contracts       Contract[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QuotationRequestItem {
  id                    String           @id @default(uuid())
  quotationRequestId    String
  materialId            String?
  description           String           // Descripción del material/servicio
  quantity             Float
  unitOfMeasure        UnitOfMeasure
  observations         String?
  
  quotationRequest      QuotationRequest @relation(fields: [quotationRequestId], references: [id], onDelete: Cascade)
  material              Material?        @relation(fields: [materialId], references: [id])
  
  // Items de cotización recibidos (para comparación)
  quotationItems       QuotationItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([quotationRequestId, description])
}

// ============================================
// COTIZACIONES (de proveedores)
// ============================================

model Quotation {
  id                  String           @id @default(uuid())
  code                String           @unique
  quotationRequestId  String
  supplierId          String
  
  // Fechas
  quotationDate       DateTime         @default(now())
  validUntil          DateTime?        // Vigencia de la cotización
  
  // Totales
  subtotal            Float            @default(0)
  discount            Float            @default(0)
  tax                 Float            @default(0)
  total               Float            @default(0)
  
  // Estado
  status              QuotationStatus  @default(PENDING)
  
  // Notas
  notes               String?
  paymentTerms        String?          // Términos de pago ofrecidos
  deliveryTime        String?          // Tiempo de entrega
  
  // Relación con usuario que recibió la cotización
  receivedById        String?
  receivedBy          User?            @relation(fields: [receivedById], references: [id])
  
  quotationRequest    QuotationRequest @relation(fields: [quotationRequestId], references: [id])
  supplier            Supplier          @relation(fields: [supplierId], references: [id])
  
  // Items cotizados
  items               QuotationItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QuotationItem {
  id                    String            @id @default(uuid())
  quotationId           String
  quotationRequestItemId String
  
  unitPrice             Float             @default(0)
  quantity              Float             @default(0)
  discount              Float             @default(0)
  total                 Float             @default(0)
  
  deliveryTime          String?           // Tiempo de entrega para este item
  availability          String?           // Disponibilidad (en stock, bajo pedido, etc.)
  brand                 String?           // Marca ofrecida
  observations          String?
  
  quotation             Quotation         @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationRequestItem  QuotationRequestItem @relation(fields: [quotationRequestItemId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([quotationId, quotationRequestItemId])
}

// ============================================
// ÓRDENES DE COMPRA
// ============================================

model PurchaseOrder {
  id                  String                 @id @default(uuid())
  code                String                 @unique
  
  // Datos generales
  supplierId         String
  projectName        String?
  description        String?
  deliveryAddress    String?
  requiredDate       DateTime?
  
  // Fechas
  orderDate          DateTime               @default(now())
  confirmationDate   DateTime?
  expectedDelivery   DateTime?
  receivedDate       DateTime?
  
  // Totales
  subtotal           Float                  @default(0)
  discount           Float                  @default(0)
  tax                Float                  @default(0)
  total              Float                  @default(0)
  
  // Estado
  status             PurchaseOrderStatus    @default(DRAFT)
  
  // Términos
  paymentTerms       String?
  deliveryTerms      String?
  
  // Usuario que creó y aprobó
  createdById        String
  createdBy          User                   @relation(fields: [createdById], references: [id])
  approvedById       String?
  approvedBy         User?                  @relation("ApprovedBy", fields: [approvedById], references: [id])
  
  supplier           Supplier               @relation(fields: [supplierId], references: [id])
  
  // Items de la orden
  items              PurchaseOrderItem[]
  
  // Historial de estados
  statusHistory      PurchaseOrderStatusHistory[]
  
  // Recepciones
  receipts           PurchaseReceipt[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchaseOrderItem {
  id                    String                  @id @default(uuid())
  purchaseOrderId       String
  materialId            String?
  description           String
  quantity              Float
  unitOfMeasure        UnitOfMeasure
  unitPrice             Float                   @default(0)
  discount              Float                   @default(0)
  total                 Float                   @default(0)
  
  // Recepciones
  quantityReceived      Float                   @default(0)
  status                PurchaseOrderItemStatus @default(PENDING)
  
  // Referencias a cotización
  quotationItemId       String?
  
  purchaseOrder         PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  material              Material?                @relation(fields: [materialId], references: [id])
  
  // Recepciones de este item
  receipts              PurchaseReceiptItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchaseOrderStatusHistory {
  id              String         @id @default(uuid())
  purchaseOrderId String
  status          PurchaseOrderStatus
  changedById     String
  changedAt       DateTime       @default(now())
  notes           String?
  
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  @@unique([purchaseOrderId, changedAt])
}

// ============================================
// RECEPCIONES DE MATERIALES
// ============================================

model PurchaseReceipt {
  id                String   @id @default(uuid())
  purchaseOrderId   String
  receiptDate       DateTime @default(now())
  receivedBy        String?
  observations     String?
  
  purchaseOrder     PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  items             PurchaseReceiptItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchaseReceiptItem {
  id                  String   @id @default(uuid())
  receiptId           String
  purchaseOrderItemId String
  quantityReceived    Float
  
  receipt             PurchaseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// PROYECTOS
// ============================================

model Project {
  id          String        @id @default(uuid())
  code        String        @unique
  name        String
  description String?
  address     String?
  city        String?
  region      String?
  clientName  String?
  clientRut   String?
  startDate   DateTime?
  endDate     DateTime?
  deadline    DateTime?
  status      ProjectStatus @default(PLANNING)
  budget      Float?
  actualCost  Float?
  contactName String?
  contactPhone String?
  contactEmail String?
  notes       String?
  
  // Órdenes de trabajo asociadas
  workOrders  WorkOrder[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// ============================================
// ÓRDENES DE TRABAJO
// ============================================

enum WorkOrderStatus {
  DRAFT
  APPROVED
  IN_PROGRESS
  COMPLETED
  SUSPENDED
  CANCELLED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum PaymentType {
  FIJO
  ANTICIPO
  POR_AVANCE
  MIXTO
}

model WorkOrder {
  id              String         @id @default(uuid())
  code            String         @unique
  supplierId      String
  title           String
  description     String?
  
  // Relación con Proyecto
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id])
  
  // Fechas y plazos
  startDate       DateTime?
  endDate         DateTime?
  executionDays   Int?           // Plazo de ejecución en días
  
  // Valores
  subtotal        Float          @default(0)
  iva             Float          @default(0)
  totalValue      Float          @default(0)
  
  // Forma de pago
  paymentType     PaymentType    @default(FIJO)
  paymentTerms    String?        // Términos de pago (ej: "50% anticipo, 50% entrega")
  
  // Estado
  status          WorkOrderStatus @default(DRAFT)
  observations    String?
  
  // Relaciones
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  items           WorkOrderItem[]
  contracts       Contract[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model WorkOrderItem {
  id              String     @id @default(uuid())
  workOrderId     String
  description     String
  quantity        Float      @default(1)
  unit            String
  unitPrice       Float
  iva             Boolean    @default(false)  // Indica si tiene IVA
  totalPrice      Float      @default(0)
  observations    String?
  
  workOrder       WorkOrder  @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

// Enum para estado del contrato
enum ContractStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  COMPLETED
  CANCELLED
}

// Enum para campo FIC
enum FicStatus {
  SI
  NO
  FIRMA
}

// Modelo Contract
model Contract {
  id              String         @id @default(uuid())
  code            String         @unique
  
  // Relaciones
  workOrderId     String?
  workOrder       WorkOrder?     @relation(fields: [workOrderId], references: [id])
  quotationRequestId String?
  quotationRequest QuotationRequest? @relation(fields: [quotationRequestId], references: [id])
  supplierId      String
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  
  // Campos principales
  startDate       DateTime?
  endDate         DateTime?
  value           Float          @default(0)
  
  // Checklist de documentos
  docContratoFirmado String       @default("NO")  // SI, NO
  docRequierePoliza  String       @default("N/A") // SI, NO, N/A
  
  // FIC
  fic             FicStatus      @default(NO)
  
  // Acta de inicio
  actaStartDate   DateTime?      // Fecha inicio del acta
  actaEndDate     DateTime?      // Fecha fin del acta
  
  // OtroSí
  otroSiNumber    Int?           // Número de otro sí
  otroSiEndDate   DateTime?      // Fecha final del otro sí
  otroSiValue     Float          @default(0)  // Valor adicional del otro sí
  
  // Valores calculados
  finalValue      Float          @default(0)  // Valor inicial + otro sí
  advancePayment  Float          @default(0)  // Anticipo sobre contrato inicial
  
  // Estado y observaciones
  status          ContractStatus @default(DRAFT)
  observations    String?
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ============================================
// SETTINGS
// ============================================

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  isSecret  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
